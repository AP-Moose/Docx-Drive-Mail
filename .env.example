# Core app
PORT=5000
NODE_ENV=development

# Database
# Optional for quick UI bring-up. If omitted, the app falls back to in-memory storage.
# Required for persistent local work and shipping.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/docx_drive_mail

# OpenAI
# Required for proposal generation and transcription.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.1
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Google OAuth
# Required for local Google Drive + Gmail integration outside Replit.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=https://developers.google.com/oauthplayground
GOOGLE_DRIVE_ROOT_FOLDER="Proposal Builder"
